{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ebbackup Workbench",
  "version": "0.1.0",
  "identifier": "com.ebbackup.workbench",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run sync:runtime && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ebbackup Workbench",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "shortDescription": "ebbackup 备份仓库桌面工作台",
    "longDescription": "ebbackup Workbench：内容寻址备份内核桌面控制台。",
    "resources": {
      "bin/ebbackup_workbench.dll": "runtime/ebbackup_workbench.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
